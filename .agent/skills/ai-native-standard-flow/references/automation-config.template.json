{
  "schemaVersion": "1.2",
  "projectType": "monolith",
  "productVersion": "v1.0",
  "currentStage": "初始化基线",
  "executionPolicy": {
    "defaultMode": "apply-safe",
    "allowSafePatch": true,
    "allowUnsafeOverwrite": false,
    "planWritesReports": false,
    "blockOnRequiredManual": true
  },
  "outputs": {
    "complianceMarkdownFile": "docs/compliance/v1.0/checklist.md",
    "complianceJsonFile": "docs/compliance/v1.0/checklist.json"
  },
  "requiredPaths": [
    "docs/compliance/v1.0/",
    "docs/product-snapshot/",
    "docs/requirements/",
    "docs/design/",
    "docs/prototype/",
    "docs/ui/",
    "docs/glossary/",
    "docs/decisions/",
    "openspec/",
    "AGENTS.md",
    ".agent/skills/",
    "standards/",
    ".github/workflows/"
  ],
  "conditionalPaths": [
    {
      "path": "docs/integration/",
      "when": "projectType == microservice",
      "required": true
    }
  ],
  "changeRules": {
    "safeAdd": [
      "docs/compliance/README.md",
      "docs/compliance/v1.0/checklist.md",
      "docs/compliance/v1.0/progress.md",
      "docs/product-snapshot/README.md",
      "docs/requirements/README.md",
      "docs/design/README.md",
      "docs/prototype/README.md",
      "docs/ui/README.md",
      "docs/ui/tokens/design-tokens.json",
      "docs/glossary/README.md",
      "docs/decisions/README.md",
      "docs/decisions/v1.0/README.md",
      "standards/coding-standards.md",
      "standards/project-structure-standards.md",
      "standards/markdown-standards.md",
      "standards/testing-standards.md",
      "standards/review-checklist.md",
      "AGENTS.md"
    ],
    "safePatch": [
    ],
    "manualOnly": [
      "MCP",
      "AI 编码助手",
      "任务管理",
      "可观测性"
    ]
  },
  "adapters": {
    "skillRegistry": { "enabled": true },
    "mcp": { "enabled": true, "mode": "manual" },
    "openSpec": { "enabled": true },
    "openSkills": { "enabled": true },
    "agentsMd": { "enabled": true },
    "qualityToolchain": { "enabled": true },
    "projectStandards": { "enabled": true }
  },
  "toolChecks": {
    "skill": {
      "requiredLevel": "required",
      "checkStage": "初始化基线"
    },
    "mcp": {
      "requiredLevel": "required",
      "mode": "manual",
      "checkStage": "技术栈确认"
    },
    "openSpec": {
      "requiredLevel": "required",
      "checkStage": "初始化基线"
    },
    "openSkills": {
      "requiredLevel": "required",
      "mode": "auto",
      "checkStage": "初始化基线"
    },
    "agentsMd": {
      "requiredLevel": "required",
      "checkStage": "初始化基线"
    },
    "aiCodingAssistant": {
      "requiredLevel": "required",
      "mode": "manual",
      "checkStage": "初始化基线"
    },
    "git": {
      "requiredLevel": "required",
      "checkStage": "初始化基线"
    },
    "versionReview": {
      "requiredLevel": "required",
      "mode": "manual",
      "checkStage": "初始化基线"
    },
    "lint": {
      "requiredLevel": "required",
      "checkStage": "技术栈确认"
    },
    "typeCheck": {
      "requiredLevel": "required",
      "checkStage": "技术栈确认"
    },
    "unitTest": {
      "requiredLevel": "required",
      "checkStage": "技术栈确认"
    },
    "ciCd": {
      "requiredLevel": "required",
      "checkStage": "初始化基线"
    },
    "prototypeMaterial": {
      "requiredLevel": "recommended",
      "checkStage": "UI/原型"
    },
    "uiMaterial": {
      "requiredLevel": "recommended",
      "checkStage": "UI/原型"
    },
    "taskManagement": {
      "requiredLevel": "recommended",
      "mode": "manual",
      "checkStage": "需求分析"
    },
    "requirementsDoc": {
      "requiredLevel": "recommended",
      "checkStage": "需求分析"
    },
    "designDoc": {
      "requiredLevel": "recommended",
      "checkStage": "技术方案"
    },
    "observability": {
      "requiredLevel": "recommended",
      "mode": "manual",
      "checkStage": "技术栈确认"
    }
  }
}
